{
  "name": "dotnet-modular-react-template",
  "version": "1.0.6",
  "description": "CLI template factory for bootstrapping a .NET + React modular-monolith product repository.",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Supremacy/dotnet-modular-react-template.git"
  },
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "bin": {
    "dotnet-modular-react-template": "scripts/bootstrap-template.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "docs/",
    "scripts/bootstrap-template.js",
    "template/",
    "!template/**/.pnpm-store/**",
    "!template/**/bin/**",
    "!template/**/coverage/**",
    "!template/**/dist/**",
    "!template/**/node_modules/**",
    "!template/**/obj/**",
    "!template/**/playwright-report/**",
    "!template/**/test-results/**",
    "!template/.husky/_/**",
    "!template/server/src/ModularTemplate.Persistence/Migrations/**"
  ],
  "keywords": [
    "dotnet",
    "react",
    "template",
    "modular-monolith",
    "aspire"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.3 <11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "pnpm exec node scripts/clean-template-artifacts.js",
    "prepare": "husky",
    "scripts:lint": "eslint scripts --max-warnings 0",
    "scripts:test": "pnpm exec node --test scripts/*.test.js",
    "template:bootstrap": "pnpm exec node scripts/bootstrap-template.js",
    "template:verify": "pnpm exec node scripts/verify-bootstrap.js",
    "template:verify:dry-run": "pnpm exec node scripts/bootstrap-template.js --product-name \"Acme Desk\" --output ../acme-desk --dry-run",
    "template:verify:full": "pnpm exec node scripts/verify-bootstrap.js --full",
    "verify": "pnpm format:check && pnpm scripts:lint && pnpm scripts:test && pnpm template:verify:dry-run && pnpm template:verify"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "21.0.0",
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  }
}
