{
  "Authentication": {
    "Oidc": {
      "Authority": "http://localhost:8080/realms/modular-template",
      "ClientId": "modular-template-host",
      "CallbackPath": "/auth/callback",
      "SignedOutCallbackPath": "/auth/signed-out"
    }
  },
  "Messaging": {
    "Modules": ["identity", "products"],
    "Rebus": {
      "QueuePrefix": "modular-template",
      "Postgres": {
        "ConnectionStringName": "modular-template-host",
        "TransportSchema": "transport",
        "TransportTable": "rebus_messages",
        "SubscriptionTable": "rebus_subscriptions",
        "AutoCreateSubscriptionTable": true
      },
      "AzureServiceBus": {
        "ConnectionStringName": "messaging-service-bus"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
