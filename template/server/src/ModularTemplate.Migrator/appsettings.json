{
  "Messaging": {
    "Rebus": {
      "QueuePrefix": "modular-template",
      "Workers": {
        "NumberOfWorkers": 1,
        "MaxParallelism": 1,
        "ShutdownTimeout": "00:00:30"
      },
      "Postgres": {
        "ConnectionStringName": "modular-template-host",
        "TransportSchema": "transport",
        "TransportTable": "rebus_messages",
        "SubscriptionTable": "rebus_subscriptions",
        "AutoCreateSubscriptionTable": true
      },
      "AzureServiceBus": {
        "ConnectionStringName": "messaging-service-bus"
      }
    }
  }
}
